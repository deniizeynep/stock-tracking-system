<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StokTakipSistemi.OzellikGosterWindow"
        Title="Teknik Özellikler" Width="350" Height="400"
        WindowStartupLocation="CenterOwner">
    
    <Grid Margin="20">
        <StackPanel Spacing="15">
            <TextBlock x:Name="txtUrunBaslik" Text="Ürün Adı" FontSize="20" FontWeight="Bold" 
                       Foreground="#0dcaf0" TextAlignment="Center"/>
            
            <Separator Background="#0dcaf0" Height="2"/>

            <TextBox x:Name="txtOzellikler" TextWrapping="Wrap" Height="250" 
                     IsReadOnly="True" Background="#2b2b2b" Foreground="White"
                     BorderThickness="0" FontSize="14"/>
            
            <Button x:Name="btnKapat" Content="Kapat" HorizontalAlignment="Stretch" 
                    HorizontalContentAlignment="Center" Background="#dc3545" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>