<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StokTakipSistemi.GuncelleWindow"
        Title="Ürün Güncelle" Width="350" Height="450"
        WindowStartupLocation="CenterOwner">
    
    <Grid>
        <StackPanel Margin="20" Spacing="15" VerticalAlignment="Center">
            <TextBlock Text="Ürün Bilgilerini Güncelle" FontSize="20" FontWeight="Bold" 
                       Foreground="#ffc107" TextAlignment="Center" Margin="0,0,0,10"/>
            
            <TextBox x:Name="txtBarkod" PlaceholderText="Barkod Numarası"/>
            <TextBox x:Name="txtUrunAdi" PlaceholderText="Ürün Adı"/>
            <TextBox x:Name="txtKategori" PlaceholderText="Kategori"/>
            <TextBox x:Name="txtFiyat" PlaceholderText="Fiyat (TL)"/>
            <TextBox x:Name="txtStok" PlaceholderText="Stok Miktarı"/>
            
           <Button x:Name="btnKaydet" Content="Değişiklikleri Kaydet" 
        Background="#FFB6C1" Foreground="White" FontWeight="Bold"
        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
        Margin="0,10,0,0" Padding="10"/>
        </StackPanel>
    </Grid>
</Window>